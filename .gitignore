# ============================================
# Dependencies (의존성 패키지)
# ============================================
# npm/yarn으로 설치된 패키지들 - package.json으로 재설치 가능
node_modules/

# ============================================
# Build Output (빌드 결과물)
# ============================================
# 빌드 시 자동 생성되는 파일들 - npm run build로 재생성 가능
dist/
build/
*.local

# ============================================
# Environment Variables (환경 변수) - 보안 중요!
# ============================================
# API 키, 비밀번호, 데이터베이스 접속 정보 등 민감한 정보
# 절대 GitHub에 올리면 안 됨!
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ============================================
# API Keys & Secrets (API 키 및 비밀 정보) - 보안 중요!
# ============================================
# 각종 서비스 인증 키 파일들
*.pem
*.key
*.cert
*.p12
secrets.json
credentials.json
service-account.json
firebase-adminsdk*.json

# ============================================
# IDE & Editor (개발 도구 설정)
# ============================================
# 개인 개발 환경 설정 - 각자 다를 수 있음
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ============================================
# OS Generated Files (운영체제 자동 생성 파일)
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ============================================
# Logs & Debug (로그 및 디버그 파일)
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Cache & Temp (캐시 및 임시 파일)
# ============================================
.cache/
.temp/
.tmp/
*.tsbuildinfo
.eslintcache
.stylelintcache
.parcel-cache/

# ============================================
# Test Coverage (테스트 커버리지 리포트)
# ============================================
coverage/
*.lcov
.nyc_output/

# ============================================
# Misc (기타)
# ============================================
# 백업 파일
*.bak
*.backup

# 압축 파일 (실수로 올라갈 수 있음)
*.zip
*.tar.gz
*.rar

# 개인 메모/TODO
TODO.md
NOTES.md
personal/
private/

# Claude Code 설정 (개인 설정)
.claude/
