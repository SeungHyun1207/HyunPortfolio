# ==========================================================
# HyunPortfolio 환경 변수 설정 가이드
# ==========================================================
# 1. 이 파일을 복사해서 .env 파일로 만드세요:
#    cp .env.example .env
# 2. 아래 각 값을 실제 값으로 채워주세요.
# 3. .env 파일은 .gitignore에 포함되어 있어 git에 올라가지 않습니다.
# ==========================================================

# ──────────────────────────────────────────────────────────
# GitHub Heatmap 프로젝트용
# /vibeProject/githeatmap 에서 사용
# ──────────────────────────────────────────────────────────

# GitHub Personal Access Token (classic)
# 발급: https://github.com/settings/tokens
# 필요 권한: read:user, public_repo
VITE_GITHUB_TOKEN=

# GitHub 유저명 (예: SeungHyun1207)
VITE_GITHUB_USERNAME=
